<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="14dp"
    android:orientation="vertical">

    <TextView
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Фото картины"
        android:textSize="16sp"/>

    <ImageView
        android:layout_marginBottom="12dp"
        android:id="@+id/imagePreview"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#EEEEEE"
        android:scaleType="centerCrop"
        android:src="@drawable/baseline_photo_library_24"/>

    <Button
        android:id="@+id/btnPickImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/reg_botton"
        android:backgroundTint="@null"
        android:text="Загрузить картину"
        android:textColor="#FFFFFF" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Название картины">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editNameImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/reg_text_fild"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Автор">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/reg_text_fild"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Высота (см)">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editHeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:background="@drawable/reg_text_fild"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ширина (см)">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editWidth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:background="@drawable/reg_text_fild"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Жанр"
        android:textSize="14sp"
        android:textColor="#9E9E9E"/>

    <Spinner
        android:layout_marginBottom="15dp"
        android:id="@+id/spinnerGenres"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/reg_text_fild"/>

    <Button
        android:layout_marginBottom="12dp"
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Добавить картину"
        android:background="@drawable/reg_botton"
        android:textColor="#FFFFFF"
        android:backgroundTint="@null"/>
</LinearLayout>